<!--
Add the following key to Info.plist if the iOS app needs to read ANTHROPIC_API_KEY
from environment AT BUILD TIME — note: Apple discourages embedding API keys in
shipped apps. For development, set the env var in the Xcode scheme.
-->
<key>UIApplicationSceneManifest</key>
<dict>
  <key>UIApplicationSupportsMultipleScenes</key>
  <false/>
</dict>
